# ===== Babe House v2 (Railway + Postgres + Gemini) =====
PORT=3000
NODE_ENV=production

# Postgres — Railway ให้ DATABASE_URL อัตโนมัติเมื่อ add Postgres plugin
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# AI — Gemini (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=30000
# ไม่ใส่ GEMINI_API_KEY = โหมด fallback (เทมเพลต ไม่ใช่ AI จริง)

# จ่ายเงิน — Stripe
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_METHODS=card,promptpay
PRICE_SATANG=49000

# อีเมล — Resend
RESEND_API_KEY=
APP_FROM_EMAIL=Babe House <noreply@yourdomain.com>
APP_BASE_URL=https://your-app.up.railway.app

# หลังบ้าน
ADMIN_KEY=

# ส่วนลด
REFERRAL_PERCENT=20
LOYALTY_PERCENT=10
LOYALTY_MIN_MONTHS=2
HOMEWORK_MIN_UPLOADS=5
